{
  "description": "Route long agent replies through lotra for human review",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/session-start-inject.ts"]
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/stop-gate.ts"],
            "asyncRewake": true
          }
        ]
      }
    ]
  }
}
