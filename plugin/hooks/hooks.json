{
  "description": "Route long agent replies through lotra for human review",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bun",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/stop-remind.ts"]
          },
          {
            "type": "command",
            "command": "bun",
            "args": ["${CLAUDE_PLUGIN_ROOT}/scripts/stop-gate.ts"],
            "asyncRewake": true,
            "timeout": 1800
          }
        ]
      }
    ]
  }
}
